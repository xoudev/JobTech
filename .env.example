# --- Copie ce fichier en .env et remplis les valeurs ---
# (The Muse fonctionne sans aucune clé : l'appli tourne déjà sans rien remplir.)

# Chemin du fichier base de données SQLite
JOBTECH_DB=jobtech.db

# --- France Travail (recommandé, source principale FR/IDF) -------------------
# Inscription gratuite : https://francetravail.io  ->  créer une application,
# souscrire à l'API "Offres d'emploi v2", récupérer identifiant + clé secrète.
FT_CLIENT_ID=
FT_CLIENT_SECRET=
# Si l'auth échoue avec "invalid_scope", essaie :
#   FT_SCOPE=application_<TON_CLIENT_ID> api_offresdemploiv2 o2dsoffre
# FT_SCOPE=api_offresdemploiv2 o2dsoffre

# --- Adzuna (optionnel, agrégateur mondial) ----------------------------------
# Inscription gratuite : https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# ADZUNA_MAX_PAGES=5

# --- The Muse (optionnel : clé seulement pour augmenter les quotas) ----------
# THEMUSE_API_KEY=
# THEMUSE_MAX_PAGES=5

# --- Connecteur JSON-LD générique (schema.org/JobPosting) --------------------
# Liste de pages carrière / job boards (séparées par des virgules) qui embarquent
# leurs offres en JSON-LD. Un seul connecteur pour potentiellement des centaines
# de sites. Laisser vide = connecteur inactif.
# JSONLD_URLS=https://exemple-boite.com/carrieres,https://autre-site.fr/jobs
